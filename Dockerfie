FROM python:3.10.8-slim-bullseye

WORKDIR /app

# Install system dependencies required for video compression and stats
RUN apt-get update && apt-get install -y --no-install-recommends \
    git wget pv jq python3-dev ffmpeg mediainfo neofetch \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements.txt
RUN pip3 install --no-cache-dir -r requirements.txt

COPY . .

# Expose port for the web server
EXPOSE 10000

# Run the Flask server and the Pyrogram bot simultaneously
# Render and Koyeb will bind to the PORT environment variable dynamically
CMD gunicorn app:app --bind 0.0.0.0:${PORT:-10000} & python3 bot.py
